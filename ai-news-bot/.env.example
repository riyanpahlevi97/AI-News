# Salin file ini ke .env dan isi dengan nilai Anda
# cp .env.example .env

# === ANTHROPIC ===
# Dapatkan di: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Claude yang digunakan untuk merangkum (opsional, default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# === GMAIL ===
# Email Gmail Anda
GMAIL_USER=email-anda@gmail.com

# App Password Gmail (BUKAN password Gmail biasa)
# Cara membuat App Password:
#   1. Buka https://myaccount.google.com/security
#   2. Aktifkan 2-Step Verification jika belum
#   3. Buka https://myaccount.google.com/apppasswords
#   4. Pilih app: Mail, device: Other → beri nama "AI News Bot"
#   5. Copy password 16 karakter yang muncul
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email tujuan (bisa sama dengan GMAIL_USER atau email lain)
RECIPIENT_EMAIL=email-anda@gmail.com
